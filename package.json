{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "client": "cd portfolio-client && npm run start",
    "server": "cd portfolio-server && npm run develop",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
